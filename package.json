{
  "name": "open-agent-harness",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -b && pnpm --filter @oah/web build",
    "clean": "tsc -b --clean && pnpm -r exec rm -rf dist .vite",
    "dev:server": "pnpm --filter @oah/server dev:api-only",
    "dev:worker": "pnpm --filter @oah/worker dev",
    "dev:controller": "pnpm --filter @oah/controller dev",
    "dev:web": "pnpm --filter @oah/web dev",
    "start:server": "pnpm --filter @oah/server start:api-only",
    "start:worker": "pnpm --filter @oah/worker start",
    "start:controller": "pnpm --filter @oah/controller start",
    "storage:sync": "python3 ${OAH_TEST_ROOT:?set OAH_TEST_ROOT}/scripts/sync_to_minio.py --root ${OAH_TEST_ROOT:?set OAH_TEST_ROOT} --delete",
    "local:up": "node ./scripts/local-stack.mjs up",
    "local:down": "node ./scripts/local-stack.mjs down",
    "version:sync": "node ./scripts/sync-root-version.mjs",
    "version:check": "node ./scripts/sync-root-version.mjs --check",
    "postversion": "pnpm version:sync",
    "typecheck": "pnpm -r exec tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:dist": "pnpm build && vitest run"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/pg": "8.15.5",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
