{
  "name": "open-agent-harness",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.2",
  "type": "module",
  "scripts": {
    "build": "tsc -b && pnpm --filter @oah/web build",
    "clean": "tsc -b --clean && pnpm -r exec rm -rf dist .vite",
    "dev:server": "node ./scripts/dev-runtime.mjs server",
    "dev:worker": "node ./scripts/dev-runtime.mjs worker",
    "dev:doctor": "node ./scripts/dev-runtime.mjs doctor",
    "dev:clean": "node ./scripts/dev-runtime.mjs clean",
    "dev:web": "pnpm --filter @oah/web dev",
    "server": "node ./apps/server/dist/index.js",
    "worker": "node ./apps/server/dist/worker.js",
    "infra:up": "docker compose -f docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f docker-compose.dev.yml down",
    "version:sync": "node ./scripts/sync-root-version.mjs",
    "version:check": "node ./scripts/sync-root-version.mjs --check",
    "postversion": "pnpm version:sync",
    "typecheck": "pnpm -r exec tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:dist": "pnpm build && vitest run"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/pg": "8.15.5",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
