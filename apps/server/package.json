{
  "name": "@oah/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch --tsconfig ./tsconfig.json src/index.ts",
    "dev:worker": "tsx watch --tsconfig ./tsconfig.json src/worker.ts",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js"
  },
  "dependencies": {
    "@oah/config": "workspace:*",
    "@oah/api-contracts": "workspace:*",
    "@oah/runtime-core": "workspace:*",
    "@oah/model-gateway": "workspace:*",
    "@oah/storage-memory": "workspace:*",
    "@oah/storage-sqlite": "workspace:*",
    "@oah/storage-postgres": "workspace:*",
    "@oah/storage-redis": "workspace:*",
    "fastify": "5.8.4",
    "pg": "8.16.3",
    "redis": "4.7.1",
    "yaml": "2.8.3"
  }
}
